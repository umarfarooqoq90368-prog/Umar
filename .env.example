# Email Configuration for Contact Form
# Copy this file to .env and fill in your details

# Your Gmail address (use App Password, not regular password)
EMAIL_USER=your-email@gmail.com

# Your Gmail App Password (generate from: Google Account > Security > 2-Step Verification > App Passwords)
EMAIL_PASS=your-app-password

# Email address where you want to receive messages (default: same as EMAIL_USER)
TO_EMAIL=umarfarooqoq90368@gmail.com

# Server port (optional, default: 3000)
PORT=3000
